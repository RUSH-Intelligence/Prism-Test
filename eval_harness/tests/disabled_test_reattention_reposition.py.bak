from __future__ import annotations

import math
import unittest

import torch

from eval_harness.sketch.sketches.reattention_sketch import ReAttentionSketch, _rotate_half


INV_FREQ = 1.0 / (1_000_000 ** (torch.arange(0, 8, 2).float() / 8))  # gemma-3 global-ish


class _FakeRotary:
    def __init__(self, inv_freq):
        self.inv_freq = inv_freq
        self.attention_scaling = 1.31  # arbitrary; must be irrelevant to the result


class _FakeAttn:
    """Minimal stand-in for a self-attn module that compress()/_reposition need."""

    layer_idx = 0
    num_heads = 2
    head_dim = 8

    def __init__(self, inv_freq):
        self.rotary_emb = _FakeRotary(inv_freq)
        # q_proj unused: we drive selection by overriding score().


def _rope(x, pos, inv_freq, scaling=1.0):
    angle = pos.view(1, 1, -1, 1).to(x.dtype) * inv_freq.view(1, 1, 1, -1).to(x.dtype)
    emb = torch.cat((angle, angle), dim=-1)
    return x * (emb.cos() * scaling) + _rotate_half(x) * (emb.sin() * scaling)


class TestReAttentionReposition(unittest.TestCase):
    def test_survivors_land_on_end_anchored_positions(self):
        """Kept keys must equal RoPE-at-new-position of the raw keys, where the
        new positions are end-anchored at [k_len - n_kept, k_len)."""
        torch.manual_seed(0)
        b, n_kv, k_len, d = 1, 2, 10, 8
        raw = torch.randn(b, n_kv, k_len, d, dtype=torch.float64)
        original_positions = torch.arange(k_len, dtype=torch.float64)

        # The cache holds keys already RoPE-rotated at their original positions,
        # with the model's attention_scaling baked in.
        cached_keys = _rope(raw, original_positions, INV_FREQ, scaling=1.31)
        values = torch.randn(b, n_kv, k_len, d, dtype=torch.float64)

        sketch = ReAttentionSketch(compression_ratio=0.4)  # keep 6 of 10
        module = _FakeAttn(INV_FREQ.double())

        # Force a deterministic, head-specific selection by stubbing score().
        # Head 0 keeps the 6 highest indices; head 1 keeps a scattered set.
        keep0 = [4, 5, 6, 7, 8, 9]
        keep1 = [0, 2, 3, 5, 7, 9]
        scores = torch.full((b, n_kv, k_len), -1e9, dtype=torch.float64)
        for i, p in enumerate(keep0):
            scores[0, 0, p] = 100 - i
        for i, p in enumerate(keep1):
            scores[0, 1, p] = 100 - i
        sketch.score = lambda *a, **k: scores  # type: ignore[assignment]

        out_keys, out_vals = sketch.compress(module, torch.empty(b, 1, d), cached_keys, values, None, {})

        n_kept = int(k_len * (1 - sketch.compression_ratio))
        new_positions = torch.arange(k_len - n_kept, k_len, dtype=torch.float64)

        for head, kept in ((0, sorted(keep0)), (1, sorted(keep1))):
            expected = _rope(
                raw[:, head : head + 1, kept, :], new_positions, INV_FREQ, scaling=1.31
            )
            self.assertTrue(
                torch.allclose(out_keys[:, head : head + 1], expected, atol=1e-9),
                f"head {head} repositioned keys diverge",
            )
            # Values are gathered (in sorted order), never rotated.
            self.assertTrue(torch.allclose(out_vals[:, head, :, :], values[:, head, kept, :]))

        # Every survivor now sits within the trained range relative to a query at k_len.
        max_rel_distance = k_len - (k_len - n_kept)
        self.assertEqual(max_rel_distance, n_kept)

    def test_reposition_false_is_plain_eviction(self):
        """With reposition=False the survivors keep their original RoPE (no shift)."""
        torch.manual_seed(1)
        b, n_kv, k_len, d = 1, 2, 8, 8
        cached_keys = torch.randn(b, n_kv, k_len, d, dtype=torch.float64)
        values = torch.randn(b, n_kv, k_len, d, dtype=torch.float64)

        sketch = ReAttentionSketch(compression_ratio=0.5, reposition=False)
        module = _FakeAttn(INV_FREQ.double())
        keep = [1, 3, 5, 7]
        scores = torch.full((b, n_kv, k_len), -1e9, dtype=torch.float64)
        for i, p in enumerate(keep):
            scores[:, :, p] = 100 - i
        sketch.score = lambda *a, **k: scores  # type: ignore[assignment]

        out_keys, _ = sketch.compress(module, torch.empty(b, 1, d), cached_keys, values, None, {})
        # Sorted-gather of the originals, untouched.
        expected = cached_keys[:, :, sorted(keep), :]
        self.assertTrue(torch.allclose(out_keys, expected))

    def test_zero_ratio_is_noop(self):
        sketch = ReAttentionSketch(compression_ratio=0.0)
        module = _FakeAttn(INV_FREQ.double())
        keys = torch.randn(1, 2, 6, 8)
        values = torch.randn(1, 2, 6, 8)
        out_k, out_v = sketch.compress(module, torch.empty(1, 1, 8), keys, values, None, {})
        self.assertIs(out_k, keys)
        self.assertIs(out_v, values)


if __name__ == "__main__":
    unittest.main()
